{
  "name": "lancache-manager",
  "private": true,
  "version": "1.9.12",
  "type": "module",
  "scripts": {
    "sync-version": "node -e \"const fs=require('fs');try{const v=fs.readFileSync('../VERSION','utf-8').trim();const pkg=require('./package.json');pkg.version=v;fs.writeFileSync('./package.json',JSON.stringify(pkg,null,2)+'\\n')}catch(e){}\"",
    "predev": "npm run sync-version",
    "prebuild": "npm run sync-version",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . && node scripts/validate-stage-keys.mjs",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "knip": "knip",
    "validate:stage-keys": "node scripts/validate-stage-keys.mjs"
  },
  "dependencies": {
    "@microsoft/signalr": "^8.0.7",
    "@number-flow/react": "^0.5.10",
    "chart.js": "^4.5.1",
    "i18next": "^26.0.3",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.542.0",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.2",
    "toml": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.3.0",
    "knip": "^5.88.1",
    "lint-staged": "^15.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.0.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,json}": [
      "prettier --write"
    ]
  }
}
